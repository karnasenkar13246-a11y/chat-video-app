<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Room: <%= roomId %></title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <% if (!authorized) { %>
    <div style="position:fixed; top:0; left:0; width:100%; height:100%; background:#121212; display:flex; justify-content:center; align-items:center; z-index:10000;">
      <div style="text-align:center; background:#1e1e1e; padding:40px; border-radius:15px; width: 90%; max-width:320px;">
        <h2 style="color:white; margin-bottom:20px;">Room Terkunci 🔒</h2>
        <form action="/<%= roomId %>" method="POST">
          <input type="password" name="password" placeholder="Masukkan Password" style="padding:12px; width:100%; border-radius:5px; border:none; margin-bottom:15px; box-sizing:border-box;" required>
          <br><button type="submit" style="padding:10px 25px; background:#007bff; border:none; color:white; border-radius:5px; cursor:pointer; width:100%; font-weight:bold;">Buka Room</button>
        </form>
        <br><a href="/" style="color:#555; text-decoration:none; font-size:12px;">Kembali ke Lobby</a>
      </div>
    </div>
  <% } else { %>
    <div id="main-container">
      <div id="video-grid"></div>
      <div id="chat-panel">
        <div id="message-container"></div>
        <form id="send-container">
          <input type="text" id="message-input" placeholder="Ketik pesan..." autocomplete="off">
          <button type="submit" id="send-button">Kirim</button>
        </form>
      </div>
    </div>
    <script> const ROOM_ID = "<%= roomId %>" </script>
    <script defer src="https://unpkg.com/peerjs@1.3.1/dist/peerjs.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="script.js"></script>
  <% } %>
</body>
</html>