<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Lobby Video Chat</title>
  <style>
    body { background: #121212; color: white; font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
    .card { background: #1e1e1e; padding: 30px; border-radius: 15px; text-align: center; width: 300px; }
    input { padding: 10px; margin: 10px 0; width: 90%; border-radius: 5px; border: 1px solid #333; background: #252525; color: white; }
    button { padding: 10px; width: 100%; background: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer; font-weight: bold; }
    button:hover { background: #0056b3; }
  </style>
</head>
<body>
  <div class="card">
    <h2>Video Chat 🔒</h2>
    <% if (error) { %> <p style="color: #ff4d4d;"><%= error %></p> <% } %>
    <hr style="border: 0.5px solid #333; margin: 20px 0;">
    <p>Buat Room Baru dengan Password:</p>
    <form action="/create-room" method="POST">
      <input type="password" name="password" placeholder="Set Password Room" required>
      <button type="submit">Buat Room Sekarang</button>
    </form>
  </div>
</body>
</html>