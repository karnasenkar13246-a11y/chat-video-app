<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lobby Video Chat</title>
  <style>
    body { background: #121212; color: white; font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
    .card { background: #1e1e1e; padding: 30px; border-radius: 15px; text-align: center; width: 90%; max-width: 350px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    input { padding: 12px; margin: 10px 0; width: 100%; border-radius: 5px; border: 1px solid #333; background: #252525; color: white; box-sizing: border-box; }
    button { padding: 12px; width: 100%; background: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer; font-weight: bold; }
    h2 { margin-bottom: 20px; color: #007bff; }
  </style>
</head>
<body>
  <div class="card">
    <h2>Video Chat Grup 👥</h2>
    <% if (error) { %> <p style="color: #ff4d4d; font-size: 14px;"><%= error %></p> <% } %>
    <form action="/enter-room" method="POST">
      <input type="text" name="roomName" placeholder="Nama Grup (Contoh: mabar)" required>
      <input type="password" name="password" placeholder="Password Grup" required>
      <button type="submit">Masuk / Buat Grup</button>
    </form>
  </div>
</body>
</html>